# Azure Horizon — Backend Environment Variables
# Sao chép file này thành .env và điền giá trị thật.
# KHÔNG commit file .env (đã được .gitignore).

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/tour_db?schema=public"

# Secret ký/verify JWT — sinh chuỗi ngẫu nhiên mạnh:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# Gmail SMTP (Nodemailer) — dùng App Password, không phải mật khẩu Gmail thường
MAIL_USER=
MAIL_PASS=

# PayOS — lấy tại https://my.payos.vn
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# ═══ LLMGate AI Gateway ═══
# Đăng ký tại https://llmgate.app/register để lấy API key
LLMGATE_API_KEY=
LLMGATE_BASE_URL=https://llmgate.app/v1
# Model chính — có thể đổi sang: claude-3-5-sonnet-20241022, gpt-4o, gpt-4o-mini
LLMGATE_MODEL=gpt-5.4-mini
# Model fallback khi primary bị lỗi/quota
LLMGATE_FALLBACK_MODEL=gpt-5.5

# Google Gemini AI (giữ lại phòng backup trực tiếp)
GEMINI_API_KEY=

# ═══ CẤU HÌNH CHUNG ═══
# Tỷ giá USD → VNĐ (dùng chung giữa Frontend & Backend)
USD_TO_VND_RATE=26331
# URL Frontend (dùng cho redirect sau thanh toán)
FRONTEND_URL=http://localhost:3001
# URL Backend (dùng cho PayOS callback)
BACKEND_URL=http://localhost:3000

# Cloudinary — lấy tại https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== Dual provider AI config (recommended) =====
# AI_PROVIDER: llmgate | openai
AI_PROVIDER=llmgate
# If empty, backend will fallback to legacy LLMGATE_API_KEY
AI_API_KEY=
# Optional custom endpoint (for llmgate or compatible gateway). Leave empty to use provider default endpoint.
AI_BASE_URL=https://llmgate.app/v1
# Always set explicit models supported by the selected provider
AI_PRIMARY_MODEL=gpt-5.4-mini
AI_FALLBACK_MODEL=gpt-5.5

# === GOOGLE OAUTH 2.0 ===
# Lay tu console.cloud.google.com -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Secret dùng cho on-demand revalidation của Next.js (khớp với frontend)
REVALIDATION_SECRET=
