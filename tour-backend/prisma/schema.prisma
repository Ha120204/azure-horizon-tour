  @@index([userId, status])                  // [PHASE 1] Index: lá»‹ch sá»­ booking user
  @@index([status, paymentStatus, createdAt]) // [PHASE 1] Index: cron job quÃ©t Ä‘Æ¡n háº¿t háº¡n
  @@index([status, paymentStatus, holdExpiresAt])
}

// =============================================
// Báº¢NG LOG THANH TOÃN (PHASE 1 - Má»šI)
// LÆ°u toÃ n bá»™ lá»‹ch sá»­ giao dá»‹ch vá»›i cá»•ng thanh toÃ¡n
// =============================================
model AssistedBookingDraft {
  id               Int                 @id @default(autoincrement())
  draftCode        String              @unique
  status           AssistedDraftStatus @default(DRAFT)

  customerId       Int?
  customer         User?               @relation("AssistedDraftCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  customerName     String?
  customerEmail    String?
  customerPhone    String?
  customerIdentityNo String?
  sourceChannel    String              @default("LIVE_CHAT")
  confirmationChannel String           @default("ZALO")
  emailForTicket   String?
  sourceTicketId   Int?
  sourceTicket     SupportTicket?      @relation(fields: [sourceTicketId], references: [id], onDelete: SetNull)

  tourId           Int?
  tour             Tour?               @relation(fields: [tourId], references: [id])
  packageId        Int?
  departureId      Int?
  numberOfPeople   Int                 @default(1)
  passengers       Json?

  quotedPrice      Float               @default(0)
  unitPriceAtDraft Float?
  voucherCode      String?
  discountAmount   Float               @default(0)
  specialRequests  String?             @db.Text
  internalNote     String?             @db.Text

  createdByStaffId Int?
  createdByStaff   User?               @relation("AssistedDraftCreatedBy", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  reviewedByAdminId Int?
  reviewedByAdmin  User?               @relation("AssistedDraftReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  reviewedAt       DateTime?
  approvalNote     String?             @db.Text
  rejectionReason  String?             @db.Text

  convertedBooking Booking?

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([createdByStaffId, status])
  @@index([sourceTicketId])
}

model PaymentTransaction {
  id             Int      @id @default(autoincrement())
  bookingId      Int
  booking        Booking  @relation(fields: [bookingId], references: [id])
  
  gateway        String   // "PAYOS" | "MANUAL"
  transactionRef String?  // MÃ£ tham chiáº¿u tá»« cá»•ng thanh toÃ¡n hoáº·c biÃªn lai
  amount         Float    // Sá»‘ tiá»n giao dá»‹ch (VNÄ)
  status         String   // "PENDING" | "SUCCESS" | "FAILED"
  rawPayload     String?  @db.Text // JSON payload gá»‘c tá»« webhook Ä‘á»ƒ Ä‘á»‘i soÃ¡t

  // â”€â”€ Audit nguá»“n tiá»n [PHASE 1] â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  // Ghi rÃµ báº±ng cÃ¡ch nÃ o tiá»n Ä‘Æ°á»£c ghi nháº­n:
  //   PAYOS_WEBHOOK               â€” PayOS gá»i webhook thÃ nh cÃ´ng
  //   PAYOS_RETURN_SYNC           â€” Return URL + gá»i láº¡i PayOS API
  //   PAYOS_MANUAL_RECONCILIATION â€” Admin xÃ¡c nháº­n áº£nh CK thá»§ cÃ´ng
  //   IN_STORE_CASH               â€” Thu tiá»n máº·t táº¡i quáº§y
  //   IN_STORE_BANK_TRANSFER      â€” Chuyá»ƒn khoáº£n táº¡i quáº§y (cÃ³ biÃªn lai)
  //   IN_STORE_CARD_POS           â€” Quáº¹t tháº» POS
  //   ADMIN_OVERRIDE              â€” Override kháº©n cáº¥p (chá»‰ SUPER_ADMIN)
  confirmedSource  String?   // Enum string, null náº¿u chÆ°a xÃ¡c nháº­n
  confirmedById    Int?      // Admin/Staff thá»±c hiá»‡n xÃ¡c nháº­n
  confirmedAt      DateTime? // Thá»i Ä‘iá»ƒm xÃ¡c nháº­n
  confirmedNote    String?   @db.Text // Ghi chÃº â€” báº¯t buá»™c vá»›i manual flows
  evidenceUrl      String?   // URL áº£nh giao dá»‹ch (Cloudinary)
  // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

  createdAt      DateTime @default(now())

  @@index([bookingId])
  @@index([confirmedSource, confirmedAt]) // TÄƒng tá»‘c thá»‘ng kÃª theo nguá»“n tiá»n
}

model BookingNotification {
  id           Int      @id @default(autoincrement())
  bookingId    Int
  booking      Booking  @relation(fields: [bookingId], references: [id])
  type         String
  channel      String
  recipient    String?
  status       String
  subject      String?
  content      String   @db.Text
  paymentUrl   String?
  qrCodeUrl    String?  @db.Text
  errorMessage String?  @db.Text
  sentAt       DateTime?
  createdById  Int?
  createdBy    User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([bookingId, type, createdAt])
  @@index([status, createdAt])
}

// --- Báº¢NG NHáº¬T KÃ HÃ€NH Äá»˜NG (AUDIT LOG) ---
model SystemLog {
  id          Int      @id @default(autoincrement())
  action      String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | ROLE_CHANGE | CANCEL_BOOKING | EXPORT | REVOKE_SESSION
  resource    String   // 'Tour' | 'Booking' | 'User' | 'Voucher' | 'Article' | 'Review' | 'Auth'
  resourceId  String?  // ID cá»§a object bá»‹ tÃ¡c Ä‘á»™ng
  targetName  String?  // TÃªn hiá»ƒn thá»‹ cá»§a object (VD: "Tour Há»™i An Heritage Walk")
  description String   @db.Text // MÃ´ táº£ hÃ nh Ä‘á»™ng (human-readable)
  oldData     Json?    // Snapshot dá»¯ liá»‡u trÆ°á»›c khi thay Ä‘á»•i
  newData     Json?    // Snapshot dá»¯ liá»‡u sau khi thay Ä‘á»•i
  ipAddress   String?  // IP cá»§a ngÆ°á»i thá»±c hiá»‡n
  userAgent   String?  // Browser/OS info
  userId      Int?     // ID Admin/Staff thá»±c hiá»‡n (null = system)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([action, createdAt])
  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@index([createdAt])
}

model AdminNotification {
  id           Int      @id @default(autoincrement())
  type         String
  resourceType String
  resourceId   String?
  title        String
  body         String   @db.Text
  href         String?
  severity     String   @default("info") // info | warning | urgent
  targetRoles  String[]
  metadata     Json?
  createdAt    DateTime @default(now())

  reads        AdminNotificationRead[]

  @@index([type, createdAt])
  @@index([resourceType, resourceId])
  @@index([createdAt])
}

model AdminNotificationRead {
  id             Int      @id @default(autoincrement())
  notificationId Int
  userId         Int
  readAt         DateTime @default(now())

  notification   AdminNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
}

model SuperRiskReview {
  id            Int       @id @default(autoincrement())
  riskKey       String    @unique
  status        String    @default("OPEN") // OPEN | REVIEWED | RESOLVED
  note          String?   @db.Text
  reviewedById Int?
  reviewedBy   User?     @relation("SuperRiskReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, updatedAt])
  @@index([reviewedById, updatedAt])
}


// --- Há»† THá»NG VOUCHER ---
enum DiscountType {
