  isFeatured  Boolean       @default(false)       // BÃ i ná»•i báº­t hiá»‡n trÃªn hero
  publishedAt DateTime?                           // Nullable Ä‘á»ƒ há»— trá»£ DRAFT
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
