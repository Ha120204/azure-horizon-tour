generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
  CUSTOMER
}

enum TourStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  COMPLETED
}

enum TravelScope {
  DOMESTIC
  INTERNATIONAL
}

enum ArticleStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
}

// =============================================
// Báº¢NG NGÆ¯á»œI DÃ™NG (USER)
// =============================================
model User {
  id        Int       @id @default(autoincrement()) 
  email     String    @unique                        
  password  String?                                 // Optional: Google users don't have password
  fullName  String
  phone     String?                                 
  avatarUrl String?
  dob       String?
  gender    String?
  identityType  String?   // "CCCD" | "PASSPORT"
  identityNo    String?   // MÃ£ sá»‘ giáº¥y tá» tuá»³ thÃ¢n
  role      Role      @default(CUSTOMER)             
  createdAt DateTime  @default(now())               
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // [PHASE 1] Soft Delete                     
  authTokenVersion Int @default(0)
  authRevokedAt DateTime?

  // -- Google OAuth --
  googleId     String?  @unique   // Google subject ID (sub)
  authProvider String   @default("local") // "local" | "google" | "both"


  bookings        Booking[]
  bookingsConfirmed Booking[]    @relation("BookingConfirmedBy")
  bookingNotifications BookingNotification[]
  userVouchers    UserVoucher[]
  chatSessions    ChatSession[]
  reviews         Review[]
  systemLogs      SystemLog[]
  adminNotificationReads AdminNotificationRead[]
  supportTickets  SupportTicket[]
  createdTours    Tour[]    @relation("TourCreatedBy")
  reviewedTours   Tour[]    @relation("TourReviewedBy")
  createdArticles Article[] @relation("ArticleCreatedBy")
  reviewedArticles Article[] @relation("ArticleReviewedBy")
  assistedDraftsCreated AssistedBookingDraft[] @relation("AssistedDraftCreatedBy")
  assistedDraftsReviewed AssistedBookingDraft[] @relation("AssistedDraftReviewedBy")
  assistedDraftsAsCustomer AssistedBookingDraft[] @relation("AssistedDraftCustomer")
  superRiskReviews SuperRiskReview[] @relation("SuperRiskReviewedBy")
}

// =============================================
// Báº¢NG ÄIá»‚M Äáº¾N (DESTINATION)
// =============================================
model Destination {
  id          Int      @id @default(autoincrement())
  name        String   @unique 
  nameEn      String?
  slug        String?  @unique // URL thÃ¢n thiá»‡n (vd: da-nang)
  description String?  @db.Text
  imageUrl    String?  
  region      String?  
  regionEn    String?
  travelScope TravelScope @default(DOMESTIC)
  countryCode String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tours       Tour[]   

  @@index([travelScope])
}

// =============================================
// Báº¢NG TOUR DU Lá»ŠCH
