  // [PHASE 2] ThÃ´ng tin chi tiáº¿t theo ngÃ y
  mealsBreakfast  Boolean  @default(false) // Bá»¯a sÃ¡ng included
  mealsLunch      Boolean  @default(false) // Bá»¯a trÆ°a included
  mealsDinner     Boolean  @default(false) // Bá»¯a tá»‘i included
  accommodation   String?                  // "Vinpearl Resort 5â­"
  accommodationEn String?
  transport       String?                  // "Xe du lá»‹ch 45 chá»—"
  transportEn     String?
  activities      String[]                 // ["Láº·n ngáº¯m san hÃ´", "Táº¯m biá»ƒn HÃ²n Táº±m"]
  activitiesEn    String[] @default([])
  imageUrl        String?                  // áº¢nh minh há»a cho ngÃ y
  timeline        Json?                    // [{"time":"08:00","activity":"Ä‚n sÃ¡ng táº¡i KS"}, ...]
  timelineEn      Json?

  @@index([tourId, dayNumber])
}

// =============================================
// Báº¢NG ÄIá»‚M Ná»”I Báº¬T TOUR (PHASE 2 - Má»šI)
// =============================================
model TourHighlight {
  id        Int    @id @default(autoincrement())
  tourId    Int
