  content   String // "Láº·n ngáº¯m san hÃ´ táº¡i HÃ²n Mun â€” 10 vá»‹nh Ä‘áº¹p nháº¥t tháº¿ giá»›i"
  contentEn String?
  icon      String @default("auto_awesome") // Material Symbol icon name
  sortOrder Int    @default(0)

  @@index([tourId, sortOrder])
}

// =============================================
// Báº¢NG CÃ‚U Há»ŽI THÆ¯á»œNG Gáº¶P (PHASE 2 - Má»šI)
// =============================================
model TourFAQ {
  id        Int    @id @default(autoincrement())
  tourId    Int
  tour      Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  question  String
  questionEn String?
  answer    String @db.Text
  answerEn  String? @db.Text
