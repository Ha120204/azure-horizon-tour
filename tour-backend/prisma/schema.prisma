// =============================================
// Báº¢NG GÃ“I TOUR (TOUR PACKAGE)
// =============================================
model TourPackage {
  id          Int      @id @default(autoincrement())
  tourId      Int
  tour        Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  name        String   // "GÃ³i TiÃªu Chuáº©n" | "GÃ³i Cao Cáº¥p" | "GÃ³i Luxury"
  nameEn      String?
  description String?  @db.Text // MÃ´ táº£ ngáº¯n vá» gÃ³i
  descriptionEn String? @db.Text
  price       Float    // GiÃ¡/ngÆ°á»i cho gÃ³i nÃ y
  badge       String?  // "POPULAR" | "BEST VALUE" | "LUXURY" | null

  // LÆ°u dáº¡ng JSON string array: ["VÃ© mÃ¡y bay khá»© há»“i", "KhÃ¡ch sáº¡n 4â˜…"]
  includes    String[] // Danh sÃ¡ch dá»‹ch vá»¥ bao gá»“m
