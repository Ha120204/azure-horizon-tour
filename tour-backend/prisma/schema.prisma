  @@index([tourId, sortOrder])
}

// =============================================
// Báº¢NG áº¢NH GALLERY TOUR (PHASE 2)
// =============================================
model TourImage {
  id        Int    @id @default(autoincrement())
  tourId    Int
  tour      Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
