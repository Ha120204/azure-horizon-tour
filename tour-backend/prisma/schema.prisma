  departures     TourDeparture[] // CÃ¡c ngÃ y khá»Ÿi hÃ nh (má»—i ngÃ y cÃ³ giÃ¡ vÃ  gháº¿ riÃªng)
  images         TourImage[]     // [PHASE 2] Bá»™ áº£nh gallery cá»§a tour
  highlights     TourHighlight[] // [PHASE 2] Äiá»ƒm ná»•i báº­t cá»§a tour
  faqs           TourFAQ[]       // [PHASE 2] CÃ¢u há»i thÆ°á»ng gáº·p

  @@index([destinationId, startDate])  // [PHASE 1] Index tÄƒng tá»‘c filter
  @@index([tourType, price])           // [PHASE 1] Index tÄƒng tá»‘c filter
}


// =============================================
// Báº¢NG Lá»ŠCH TRÃŒNH TOUR THEO NGÃ€Y (PHASE 1 - Má»šI)
// =============================================
model TourItinerary {
  id              Int      @id @default(autoincrement())
  tourId          Int
  tour            Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  dayNumber       Int      // NgÃ y thá»© máº¥y (1, 2, 3...)
  title           String   // "KhÃ¡m phÃ¡ Há»™i An cá»• kÃ­nh"
  titleEn         String?
  description     String   @db.Text // MÃ´ táº£ chi tiáº¿t hoáº¡t Ä‘á»™ng trong ngÃ y
