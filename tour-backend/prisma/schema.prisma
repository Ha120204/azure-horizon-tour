  @@index([tourId, departureDate])
  @@index([category, flashSaleEndsAt]) // [FLASH SALE] TÄƒng tá»‘c query lá»c khuyáº¿n mÃ£i
}

// --- CÃC ENUM CHO Äáº¶T TOUR ---
enum BookingStatus {
  PENDING            // Chá» xÃ¡c nháº­n
  CONFIRMED          // ÄÃ£ chá»‘t
  CANCEL_REQUESTED   // KhÃ¡ch Ä‘Ã£ gá»­i yÃªu cáº§u há»§y, chá» Admin duyá»‡t
