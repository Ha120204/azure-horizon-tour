// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
  CUSTOMER
}

enum TourStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  COMPLETED
}

enum ArticleStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
}

// =============================================
// BẢNG NGƯỜI DÙNG (USER)
// =============================================
model User {
  id        Int       @id @default(autoincrement()) 
  email     String    @unique                        
  password  String                                  
  fullName  String
  phone     String?                                 
  avatarUrl String?
  dob       String?
  gender    String?
  identityType  String?   // "CCCD" | "PASSPORT"
  identityNo    String?   // Mã số giấy tờ tuỳ thân
  role      Role      @default(CUSTOMER)             
  createdAt DateTime  @default(now())               
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // [PHASE 1] Soft Delete                     

  bookings        Booking[]
  bookingNotifications BookingNotification[]
  userVouchers    UserVoucher[]
  chatSessions    ChatSession[]
  reviews         Review[]
  systemLogs      SystemLog[]
  supportTickets  SupportTicket[]
  createdTours    Tour[]    @relation("TourCreatedBy")
  reviewedTours   Tour[]    @relation("TourReviewedBy")
  createdArticles Article[] @relation("ArticleCreatedBy")
  reviewedArticles Article[] @relation("ArticleReviewedBy")
  assistedDraftsCreated AssistedBookingDraft[] @relation("AssistedDraftCreatedBy")
  assistedDraftsReviewed AssistedBookingDraft[] @relation("AssistedDraftReviewedBy")
  assistedDraftsAsCustomer AssistedBookingDraft[] @relation("AssistedDraftCustomer")
}

// =============================================
// BẢNG ĐIỂM ĐẾN (DESTINATION)
// =============================================
model Destination {
  id          Int      @id @default(autoincrement())
  name        String   @unique 
  slug        String?  @unique // URL thân thiện (vd: da-nang)
  description String?  @db.Text
  imageUrl    String?  
  region      String?  

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tours       Tour[]   
}

// =============================================
// BẢNG TOUR DU LỊCH
// =============================================
model Tour {
  id             Int         @id @default(autoincrement())
  tourCode       String      @unique @default(uuid())
  name           String
  description    String      @db.Text
  price          Float
  
  destinationId  Int
  destination    Destination @relation(fields: [destinationId], references: [id])
  
  startDate      DateTime
  duration       String      @default("Chưa xác định")
  availableSeats Int
  imageUrl       String?
  averageRating  Float       @default(0)
  tourType       String      @default("Luxury Retreat")
  departurePoint String?                             // Điểm khởi hành mặc định (VD: "TP. Hồ Chí Minh")
  
  // ── Workflow fields ──────────────────────────────────────────────
  status         TourStatus  @default(PUBLISHED)    // Trạng thái duyệt
  publishedAt    DateTime?                           // Thời điểm xuất bản
  reviewNote     String?     @db.Text               // Lý do từ chối (Admin ghi)
  createdById    Int?                               // Staff/Admin tạo
  reviewedById   Int?                               // Admin duyệt/từ chối
  createdBy      User?       @relation("TourCreatedBy",  fields: [createdById],  references: [id], onDelete: SetNull)
  reviewedBy     User?       @relation("TourReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  // ─────────────────────────────────────────────────────────────────

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?   // [PHASE 1] Soft Delete

  bookings       Booking[]
  assistedDrafts AssistedBookingDraft[]
  reviews        Review[]
  itinerary      TourItinerary[] // [PHASE 1] Lịch trình theo ngày
  packages       TourPackage[]   // Các gói tour (Tiêu Chuẩn / Cao Cấp / Luxury)
  departures     TourDeparture[] // Các ngày khởi hành (mỗi ngày có giá và ghế riêng)
  images         TourImage[]     // [PHASE 2] Bộ ảnh gallery của tour
  highlights     TourHighlight[] // [PHASE 2] Điểm nổi bật của tour
  faqs           TourFAQ[]       // [PHASE 2] Câu hỏi thường gặp

  @@index([destinationId, startDate])  // [PHASE 1] Index tăng tốc filter
  @@index([tourType, price])           // [PHASE 1] Index tăng tốc filter
}


// =============================================
// BẢNG LỊCH TRÌNH TOUR THEO NGÀY (PHASE 1 - MỚI)
// =============================================
model TourItinerary {
  id              Int      @id @default(autoincrement())
  tourId          Int
  tour            Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  dayNumber       Int      // Ngày thứ mấy (1, 2, 3...)
  title           String   // "Khám phá Hội An cổ kính"
  description     String   @db.Text // Mô tả chi tiết hoạt động trong ngày

  // [PHASE 2] Thông tin chi tiết theo ngày
  mealsBreakfast  Boolean  @default(false) // Bữa sáng included
  mealsLunch      Boolean  @default(false) // Bữa trưa included
  mealsDinner     Boolean  @default(false) // Bữa tối included
  accommodation   String?                  // "Vinpearl Resort 5⭐"
  transport       String?                  // "Xe du lịch 45 chỗ"
  activities      String[]                 // ["Lặn ngắm san hô", "Tắm biển Hòn Tằm"]
  imageUrl        String?                  // Ảnh minh họa cho ngày
  timeline        Json?                    // [{"time":"08:00","activity":"Ăn sáng tại KS"}, ...]

  @@index([tourId, dayNumber])
}

// =============================================
// BẢNG ĐIỂM NỔI BẬT TOUR (PHASE 2 - MỚI)
// =============================================
model TourHighlight {
  id        Int    @id @default(autoincrement())
  tourId    Int
  tour      Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  content   String // "Lặn ngắm san hô tại Hòn Mun — 10 vịnh đẹp nhất thế giới"
  icon      String @default("auto_awesome") // Material Symbol icon name
  sortOrder Int    @default(0)

  @@index([tourId, sortOrder])
}

// =============================================
// BẢNG CÂU HỎI THƯỜNG GẶP (PHASE 2 - MỚI)
// =============================================
model TourFAQ {
  id        Int    @id @default(autoincrement())
  tourId    Int
  tour      Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  question  String
  answer    String @db.Text
  sortOrder Int    @default(0)

  @@index([tourId, sortOrder])
}

// =============================================
// BẢNG ẢNH GALLERY TOUR (PHASE 2)
// =============================================
model TourImage {
  id        Int    @id @default(autoincrement())
  tourId    Int
  tour      Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  url       String // Cloudinary secure_url
  altText   String @default("") // Alt text cho SEO
  sortOrder Int    @default(0)  // Thứ tự hiển thị (0 = ảnh đầu tiên / ảnh bìa)

  @@index([tourId, sortOrder])
}

// =============================================
// BẢNG GÓI TOUR (TOUR PACKAGE)
// =============================================
model TourPackage {
  id          Int      @id @default(autoincrement())
  tourId      Int
  tour        Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  name        String   // "Gói Tiêu Chuẩn" | "Gói Cao Cấp" | "Gói Luxury"
  description String?  @db.Text // Mô tả ngắn về gói
  price       Float    // Giá/người cho gói này
  badge       String?  // "POPULAR" | "BEST VALUE" | "LUXURY" | null

  // Lưu dạng JSON string array: ["Vé máy bay khứ hồi", "Khách sạn 4★"]
  includes    String[] // Danh sách dịch vụ bao gồm
  excludes    String[] // Danh sách không bao gồm

  sortOrder   Int      @default(0) // Thứ tự hiển thị
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tourId, sortOrder])
}

// =============================================
// BẢNG NGÀY KHỞI HÀNH (TOUR DEPARTURE)
// =============================================
model TourDeparture {
  id             Int      @id @default(autoincrement())
  tourId         Int
  tour           Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  departureDate  DateTime              // Ngày khởi hành cụ thể
  price          Float?                // Null = dùng tour.price làm fallback
  availableSeats Int      @default(0)  // Số ghế còn lại cho ngày này
  maxSeats       Int?                  // [FLASH SALE] Tổng ghế ban đầu — dùng tính % đã đặt thực tế
  note           String?               // Ghi chú tự do (VD: "Giá ưu đãi cuối tuần")
  category       String?               // [FLASH SALE] 'FLASH_SALE' | 'EARLY_BIRD' | 'LAST_MINUTE' | null
  flashSaleEndsAt DateTime?            // [FLASH SALE] Thời điểm kết thúc ưu đãi (null = không giới hạn)

  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tourId, departureDate])
  @@index([category, flashSaleEndsAt]) // [FLASH SALE] Tăng tốc query lọc khuyến mãi
}

// --- CÁC ENUM CHO ĐẶT TOUR ---
enum BookingStatus {
  PENDING            // Chờ xác nhận
  CONFIRMED          // Đã chốt
  CANCEL_REQUESTED   // Khách đã gửi yêu cầu hủy, chờ Admin duyệt
  CANCELLED          // Đã hủy
}

enum PaymentStatus {
  UNPAID      // Chưa thanh toán
  PROCESSING  // Đang chờ xử lý
  PAID        // Đã thanh toán thành công
  FAILED      // Thanh toán thất bại
}

enum AssistedDraftStatus {
  DRAFT
  PENDING_APPROVAL
  NEEDS_REVISION
  REJECTED
  CONVERTED
}

// =============================================
// BẢNG ĐẶT TOUR (BOOKING)
// =============================================
model Booking {
  id               Int           @id @default(autoincrement())
  bookingCode      String        @unique @default(uuid()) // Mã Đơn Hàng (VD: BKG-260324-X9F2)
  userId           Int
  tourId           Int
  numberOfPeople   Int
  totalPrice       Float
  unitPriceAtBooking Float?      // [PHASE 1] Đóng băng giá vé tại thời điểm đặt
  
  departureId      Int?          // [PHASE 2] Liên kết đến Lịch khởi hành
  packageId        Int?          // [PHASE 2] Liên kết đến Gói Tour
  contactInfo      Json?         // [PHASE 2] Thông tin liên hệ người đặt (tên, email, phone)
  passengers       Json?         // [PHASE 2] Danh sách hành khách
  
  status           BookingStatus @default(PENDING)
  paymentStatus    PaymentStatus @default(UNPAID)
  vnpayTxnRef      String?       // Mã giao dịch từ cổng thanh toán để đối soát
  isAssistedBooking Boolean      @default(false)
  assistedDraftId  Int?          @unique
  
  voucherCode      String?       // Mã voucher đã áp dụng (nếu có)
  discountAmount   Float         @default(0) // Số tiền đã giảm (VNĐ)

  // ── Cancellation fields ──────────────────────────────────────────
  cancelReason        String?   @db.Text  // Lý do hủy của khách
  cancelRequestedAt   DateTime?           // Thời điểm gửi yêu cầu hủy
  cancelledAt         DateTime?           // Thời điểm thực sự hủy
  cancelledBy         String?             // "CUSTOMER" | "ADMIN" | "SYSTEM"
  refundAmount        Float?              // Số tiền hoàn lại thực tế (VNĐ)
  refundNote          String?   @db.Text  // Ghi chú hoàn tiền / lý do từ chối
  refundBankDetails   Json?               // Thông tin nhận hoàn tiền (Ngân hàng, STK, Tên chủ TK)
  refundedAt          DateTime?           // Thời điểm Admin thực sự chuyển khoản hoàn tiền
  // ─────────────────────────────────────────────────────────────────

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?     // [PHASE 1] Soft Delete

  // Kết nối (Relations)
  user             User          @relation(fields: [userId], references: [id])
  tour             Tour          @relation(fields: [tourId], references: [id])
  assistedDraft    AssistedBookingDraft? @relation(fields: [assistedDraftId], references: [id], onDelete: SetNull)
  transactions     PaymentTransaction[] // [PHASE 1] Log thanh toán
  notifications    BookingNotification[]

  @@index([userId, status])                  // [PHASE 1] Index: lịch sử booking user
  @@index([status, paymentStatus, createdAt]) // [PHASE 1] Index: cron job quét đơn hết hạn
}

// =============================================
// BẢNG LOG THANH TOÁN (PHASE 1 - MỚI)
// Lưu toàn bộ lịch sử giao dịch với cổng thanh toán
// =============================================
model AssistedBookingDraft {
  id               Int                 @id @default(autoincrement())
  draftCode        String              @unique
  status           AssistedDraftStatus @default(DRAFT)

  customerId       Int?
  customer         User?               @relation("AssistedDraftCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  customerName     String?
  customerEmail    String?
  customerPhone    String?
  customerIdentityNo String?
  sourceChannel    String              @default("LIVE_CHAT")
  confirmationChannel String           @default("ZALO")
  emailForTicket   String?
  sourceTicketId   Int?
  sourceTicket     SupportTicket?      @relation(fields: [sourceTicketId], references: [id], onDelete: SetNull)

  tourId           Int?
  tour             Tour?               @relation(fields: [tourId], references: [id])
  packageId        Int?
  departureId      Int?
  numberOfPeople   Int                 @default(1)
  passengers       Json?

  quotedPrice      Float               @default(0)
  unitPriceAtDraft Float?
  voucherCode      String?
  discountAmount   Float               @default(0)
  specialRequests  String?             @db.Text
  internalNote     String?             @db.Text

  createdByStaffId Int?
  createdByStaff   User?               @relation("AssistedDraftCreatedBy", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  reviewedByAdminId Int?
  reviewedByAdmin  User?               @relation("AssistedDraftReviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  reviewedAt       DateTime?
  approvalNote     String?             @db.Text
  rejectionReason  String?             @db.Text

  convertedBooking Booking?

  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([createdByStaffId, status])
  @@index([sourceTicketId])
}

model PaymentTransaction {
  id             Int      @id @default(autoincrement())
  bookingId      Int
  booking        Booking  @relation(fields: [bookingId], references: [id])
  
  gateway        String   // "PAYOS" | "SEPAY" | "MANUAL"
  transactionRef String?  // Mã tham chiếu từ cổng thanh toán
  amount         Float    // Số tiền giao dịch (VNĐ)
  status         String   // "PENDING" | "SUCCESS" | "FAILED"
  rawPayload     String?  @db.Text // JSON payload gốc từ webhook để đối soát
  
  createdAt      DateTime @default(now())

  @@index([bookingId])
}

model BookingNotification {
  id           Int      @id @default(autoincrement())
  bookingId    Int
  booking      Booking  @relation(fields: [bookingId], references: [id])
  type         String
  channel      String
  recipient    String?
  status       String
  subject      String?
  content      String   @db.Text
  paymentUrl   String?
  qrCodeUrl    String?  @db.Text
  errorMessage String?  @db.Text
  sentAt       DateTime?
  createdById  Int?
  createdBy    User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([bookingId, type, createdAt])
  @@index([status, createdAt])
}

// --- BẢNG NHẬT KÝ HÀNH ĐỘNG (AUDIT LOG) ---
model SystemLog {
  id          Int      @id @default(autoincrement())
  action      String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | ROLE_CHANGE | CANCEL_BOOKING | EXPORT
  resource    String   // 'Tour' | 'Booking' | 'User' | 'Voucher' | 'Article' | 'Review' | 'Auth'
  resourceId  String?  // ID của object bị tác động
  targetName  String?  // Tên hiển thị của object (VD: "Tour Hội An Heritage Walk")
  description String   @db.Text // Mô tả hành động (human-readable)
  oldData     Json?    // Snapshot dữ liệu trước khi thay đổi
  newData     Json?    // Snapshot dữ liệu sau khi thay đổi
  ipAddress   String?  // IP của người thực hiện
  userAgent   String?  // Browser/OS info
  userId      Int?     // ID Admin/Staff thực hiện (null = system)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([action, createdAt])
  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@index([createdAt])
}


// --- HỆ THỐNG VOUCHER ---
enum DiscountType {
  PERCENTAGE    // Giảm theo %
  FIXED_AMOUNT  // Giảm số tiền cố định (VNĐ)
}

model Voucher {
  id            Int           @id @default(autoincrement())
  code          String        @unique           // Mã voucher: AZURE2026
  label         String                          // "Premium Escape"
  description   String        @db.Text          // Mô tả điều kiện
  discountType  DiscountType                    // PERCENTAGE hoặc FIXED_AMOUNT
  discountValue Float                           // 15 (= 15%) hoặc 500000 (= 500.000 VNĐ)
  minOrderValue Float         @default(0)       // Giá trị đơn tối thiểu để dùng
  maxUses       Int           @default(100)     // Tổng lượt sử dụng toàn hệ thống
  usedCount     Int           @default(0)       // Đã dùng bao nhiêu lần
  expiresAt     DateTime                        // Ngày hết hạn
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())

  userVouchers  UserVoucher[]
}

model UserVoucher {
  id         Int       @id @default(autoincrement())
  userId     Int
  voucherId  Int
  isUsed     Boolean   @default(false)         // Đã sử dụng chưa
  savedAt    DateTime  @default(now())         // Ngày lưu vào ví

  user       User      @relation(fields: [userId], references: [id])
  voucher    Voucher   @relation(fields: [voucherId], references: [id])

  @@unique([userId, voucherId])                // Mỗi user chỉ lưu mỗi voucher 1 lần
}

// --- HỆ THỐNG BÀI VIẾT (JOURNAL / BLOG) ---
model Article {
  id          Int           @id @default(autoincrement())
  slug        String        @unique               // URL thân thiện
  category    String                              // "GUIDES", "INSPIRATION", "CULTURE", "GASTRONOMY"
  title       String
  excerpt     String        @db.Text              // Tóm tắt ngắn hiển thị trên card
  content     String        @db.Text              // Nội dung đầy đủ (HTML)
  imageUrl    String
  author      String
  readTime    Int           @default(5)           // Thời gian đọc (phút)
  isFeatured  Boolean       @default(false)       // Bài nổi bật hiện trên hero
  publishedAt DateTime?                           // Nullable để hỗ trợ DRAFT
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?                           // Soft Delete (thùng rác)

  // ── Workflow fields ──────────────────────────────────────────────
  status        ArticleStatus @default(PUBLISHED) // Trạng thái duyệt
  reviewNote    String?       @db.Text             // Lý do từ chối (Admin ghi)
  createdById   Int?                               // Staff/Admin tạo
  reviewedById  Int?                               // Admin duyệt/từ chối
  createdBy     User?         @relation("ArticleCreatedBy",  fields: [createdById],  references: [id], onDelete: SetNull)
  reviewedBy    User?         @relation("ArticleReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  // ─────────────────────────────────────────────────────────────────
}

// --- HỢP PHẦN AI CONCIERGE (LƯU TRỮ LỊCH SỬ CHAT) ---
model ChatSession {
  id        String   @id @default(uuid())
  userId    Int?     // Thuộc về User nào (có thể null nếu khách chưa đăng nhập)
  user      User?    @relation(fields: [userId], references: [id])
  
  messages  ChatMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  role      String   // 'user' | 'model' | 'system'
  content   String   @db.Text
  
  createdAt DateTime @default(now())
}

// --- HỆ THỐNG ĐÁNH GIÁ (REVIEWS) ---
model Review {
  id         Int      @id @default(autoincrement())
  rating     Int      // Từ 1 đến 5 sao
  content    String   @db.Text
  imageUrls  String[] // Danh sách các ảnh đính kèm (Lưu mảng trên Postgres)

  isHidden   Boolean  @default(false) // Admin ẩn review
  adminReply String?  @db.Text        // Admin phản hồi review

  tourId    Int
  tour      Tour     @relation(fields: [tourId], references: [id])

  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tourId, rating])   // Index tăng tốc filter review
  @@index([isHidden])         // Index cho admin filter ẩn/hiện
}

// =============================================
// BẢNG NGƯỜI ĐĂNG KÝ NHẬN TIN (NEWSLETTER)
// =============================================
model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// =============================================
// BẢNG CÀI ĐẶT HỆ THỐNG (KEY-VALUE STORE)
// =============================================
model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique   // VD: "company_name", "booking_hold_minutes"
  value       String   @db.Text  // Giá trị (luôn lưu dạng String)
  label       String             // Tên hiển thị: "Tên công ty"
  description String?            // Mô tả thêm
  group       String             // Nhóm: "company" | "booking" | "announcement"
  updatedAt   DateTime @updatedAt
  updatedBy   Int?               // ID admin đã chỉnh sửa lần cuối
}

// =============================================
// HỀ THỐNG HỔ TRỢ KHÁCH HÀNG (SUPPORT TICKETS)
// =============================================
model SupportTicket {
  id              Int      @id @default(autoincrement())
  accessCode      String?  @default(uuid()) @unique // [FIX] Bắt buộc dùng để khách vãng lai xem ticket, chống lộ dữ liệu
  customerName    String
  customerEmail   String
  customerPhone   String?
  bookingRef      String?                // Mã booking liên quan (nếu có)
  subject         String
  message         String   @db.Text
  category        String   @default("general") // booking|payment|reschedule|complaint|general
  status          String   @default("NEW")     // NEW|IN_PROGRESS|RESOLVED
  assignedStaffId Int?                         // Staff được assign xử lý
  rating          Int?                         // Đánh giá của khách sau khi RESOLVED (1-5)

  // Liên kết tới tài khoản người dùng (nullable — guest submissions không có)
  userId          Int?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  assistedDrafts  AssistedBookingDraft[]
  replies         TicketReply[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([customerEmail])
  @@index([userId])
}

model TicketReply {
  id         Int      @id @default(autoincrement())
  ticketId   Int
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderType String                          // "staff" | "customer"
  senderName String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([ticketId])
}
