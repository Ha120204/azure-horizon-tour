// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
  CUSTOMER
}

// Thiết kế bảng User
model User {
  id        Int      @id @default(autoincrement()) 
  email     String   @unique                        
  password  String                                  
  fullName  String
  phone     String?                                 
  avatarUrl String?
  role      Role     @default(CUSTOMER)             
  createdAt DateTime @default(now())               
  updatedAt DateTime @updatedAt                     
  bookings  Booking[]
  userVouchers UserVoucher[]
}
model Destination {
  id          Int      @id @default(autoincrement())
  name        String   @unique 
  slug        String?  @unique // URL thân thiện (vd: da-nang)
  description String?  @db.Text
  imageUrl    String?  
  region      String?  

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tours       Tour[]   
}
// Bảng Tour du lịch
model Tour {
  id             Int         @id @default(autoincrement())
  tourCode       String      @unique @default(uuid())
  name           String
  description    String      @db.Text
  price          Float
  
  destinationId  Int
  destination    Destination @relation(fields: [destinationId], references: [id])
  
  startDate      DateTime
  duration       String      @default("Chưa xác định")
  availableSeats Int
  imageUrl       String?
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  bookings       Booking[]
}

// --- CÁC ENUM CHO ĐẶT TOUR ---
enum BookingStatus {
  PENDING   // Chờ xác nhận
  CONFIRMED // Đã chốt
  CANCELLED // Đã hủy
}

enum PaymentStatus {
  UNPAID      // Chưa thanh toán
  PROCESSING  // Đang chờ VNPAY xử lý
  PAID        // Đã thanh toán thành công
  FAILED      // Thanh toán thất bại
}

// --- BẢNG ĐẶT TOUR (BOOKING) ---
model Booking {
  id             Int           @id @default(autoincrement())
  bookingCode    String        @unique @default(uuid()) // [BỔ SUNG]: Mã Đơn Hàng (VD: BKG-260324-X9F2)
  userId         Int
  tourId         Int
  numberOfPeople Int
  totalPrice     Float
  
  status         BookingStatus @default(PENDING)
  paymentStatus  PaymentStatus @default(UNPAID)
  vnpayTxnRef    String?       // Mã giao dịch từ VNPAY để đối soát
  
  voucherCode    String?       // Mã voucher đã áp dụng (nếu có)
  discountAmount Float         @default(0) // Số tiền đã giảm (USD)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Kết nối (Relations)
  user           User          @relation(fields: [userId], references: [id])
  tour           Tour          @relation(fields: [tourId], references: [id])
}

// --- BẢNG NHẬT KÝ HỆ THỐNG (DÀNH CHO SUPER ADMIN) ---
model SystemLog {
  id          Int      @id @default(autoincrement())
  adminId     Int      // ID của Admin/Staff thực hiện hành động
  action      String   // Tên hành động (VD: CANCEL_BOOKING)
  description String   @db.Text // Mô tả chi tiết
  ipAddress   String?  // Ghi lại IP 
  createdAt   DateTime @default(now())
}

// --- HỆ THỐNG VOUCHER ---
enum DiscountType {
  PERCENTAGE    // Giảm theo %
  FIXED_AMOUNT  // Giảm số tiền cố định (USD)
}

model Voucher {
  id            Int           @id @default(autoincrement())
  code          String        @unique           // Mã voucher: AZURE2026
  label         String                          // "Premium Escape"
  description   String        @db.Text          // Mô tả điều kiện
  discountType  DiscountType                    // PERCENTAGE hoặc FIXED_AMOUNT
  discountValue Float                           // 15 (= 15%) hoặc 500 (= $500)
  minOrderValue Float         @default(0)       // Giá trị đơn tối thiểu để dùng
  maxUses       Int           @default(100)     // Tổng lượt sử dụng toàn hệ thống
  usedCount     Int           @default(0)       // Đã dùng bao nhiêu lần
  expiresAt     DateTime                        // Ngày hết hạn
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())

  userVouchers  UserVoucher[]
}

model UserVoucher {
  id         Int       @id @default(autoincrement())
  userId     Int
  voucherId  Int
  isUsed     Boolean   @default(false)         // Đã sử dụng chưa
  savedAt    DateTime  @default(now())         // Ngày lưu vào ví

  user       User      @relation(fields: [userId], references: [id])
  voucher    Voucher   @relation(fields: [voucherId], references: [id])

  @@unique([userId, voucherId])                // Mỗi user chỉ lưu mỗi voucher 1 lần
}

// --- HỆ THỐNG BÀI VIẾT (JOURNAL / BLOG) ---
model Article {
  id          Int      @id @default(autoincrement())
  slug        String   @unique               // URL thân thiện: "whispers-of-the-highlands"
  category    String                          // "GUIDES", "INSPIRATION", "CULTURE", "GASTRONOMY"
  title       String
  excerpt     String   @db.Text              // Tóm tắt ngắn hiển thị trên card
  content     String   @db.Text              // Nội dung đầy đủ (HTML)
  imageUrl    String
  author      String
  readTime    Int      @default(5)           // Thời gian đọc (phút)
  isFeatured  Boolean  @default(false)       // Bài nổi bật hiện trên hero
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}