// =============================================
// Báº¢NG Äáº¶T TOUR (BOOKING)
// =============================================
model Booking {
  id               Int           @id @default(autoincrement())
  bookingCode      String        @unique @default(uuid()) // MÃ£ ÄÆ¡n HÃ ng (VD: BKG-260324-X9F2)
  userId           Int
  tourId           Int
  numberOfPeople   Int
  totalPrice       Float
  unitPriceAtBooking Float?      // [PHASE 1] ÄÃ³ng bÄƒng giÃ¡ vÃ© táº¡i thá»i Ä‘iá»ƒm Ä‘áº·t
  
  departureId      Int?          // [PHASE 2] LiÃªn káº¿t Ä‘áº¿n Lá»‹ch khá»Ÿi hÃ nh
  packageId        Int?          // [PHASE 2] LiÃªn káº¿t Ä‘áº¿n GÃ³i Tour
  contactInfo      Json?         // [PHASE 2] ThÃ´ng tin liÃªn há»‡ ngÆ°á»i Ä‘áº·t (tÃªn, email, phone)
  passengers       Json?         // [PHASE 2] Danh sÃ¡ch hÃ nh khÃ¡ch
  
  status           BookingStatus @default(PENDING)
  paymentStatus    PaymentStatus @default(UNPAID)
  paymentMethod    PaymentMethod @default(PAYOS)
  holdExpiresAt    DateTime?
  confirmedById    Int?
  confirmedBy      User?         @relation("BookingConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)
  paymentGatewayTxnRef String?   // MÃ£ giao dá»‹ch tá»« cá»•ng thanh toÃ¡n Ä‘á»ƒ Ä‘á»‘i soÃ¡t
  isAssistedBooking Boolean      @default(false)
  assistedDraftId  Int?          @unique
  
  voucherCode      String?       // MÃ£ voucher Ä‘Ã£ Ã¡p dá»¥ng (náº¿u cÃ³)
  discountAmount   Float         @default(0) // Sá»‘ tiá»n Ä‘Ã£ giáº£m (VNÄ)

  // â”€â”€ Cancellation fields â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  cancelReason        String?   @db.Text  // LÃ½ do há»§y cá»§a khÃ¡ch
  cancelRequestedAt   DateTime?           // Thá»i Ä‘iá»ƒm gá»­i yÃªu cáº§u há»§y
  cancelledAt         DateTime?           // Thá»i Ä‘iá»ƒm thá»±c sá»± há»§y
  cancelledBy         String?             // "CUSTOMER" | "ADMIN" | "SYSTEM"
  refundAmount        Float?              // Sá»‘ tiá»n hoÃ n láº¡i thá»±c táº¿ (VNÄ)
  refundNote          String?   @db.Text  // Ghi chÃº hoÃ n tiá»n / lÃ½ do tá»« chá»‘i
  refundBankDetails   Json?               // ThÃ´ng tin nháº­n hoÃ n tiá»n (NgÃ¢n hÃ ng, STK, TÃªn chá»§ TK)
  refundedAt          DateTime?           // Thá»i Ä‘iá»ƒm Admin thá»±c sá»± chuyá»ƒn khoáº£n hoÃ n tiá»n
  // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?     // [PHASE 1] Soft Delete

  // Káº¿t ná»‘i (Relations)
  user             User          @relation(fields: [userId], references: [id])
  tour             Tour          @relation(fields: [tourId], references: [id])
  assistedDraft    AssistedBookingDraft? @relation(fields: [assistedDraftId], references: [id], onDelete: SetNull)
  transactions     PaymentTransaction[] // [PHASE 1] Log thanh toÃ¡n
  notifications    BookingNotification[]
