  departureDate  DateTime              // NgÃ y khá»Ÿi hÃ nh cá»¥ thá»ƒ
  price          Float?                // Null = dÃ¹ng tour.price lÃ m fallback
  availableSeats Int      @default(0)  // Sá»‘ gháº¿ cÃ²n láº¡i cho ngÃ y nÃ y
  maxSeats       Int?                  // [FLASH SALE] Tá»•ng gháº¿ ban Ä‘áº§u â€” dÃ¹ng tÃ­nh % Ä‘Ã£ Ä‘áº·t thá»±c táº¿
  note           String?               // Ghi chÃº tá»± do (VD: "GiÃ¡ Æ°u Ä‘Ã£i cuá»‘i tuáº§n")
  noteEn         String?
  category       String?               // [FLASH SALE] 'FLASH_SALE' | 'EARLY_BIRD' | 'LAST_MINUTE' | null
