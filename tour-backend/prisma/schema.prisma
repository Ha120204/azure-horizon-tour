  // â”€â”€ Workflow fields â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  status         TourStatus  @default(PUBLISHED)    // Tráº¡ng thÃ¡i duyá»‡t
  publishedAt    DateTime?                           // Thá»i Ä‘iá»ƒm xuáº¥t báº£n
  reviewNote     String?     @db.Text               // LÃ½ do tá»« chá»‘i (Admin ghi)
  createdById    Int?                               // Staff/Admin táº¡o
  reviewedById   Int?                               // Admin duyá»‡t/tá»« chá»‘i
  createdBy      User?       @relation("TourCreatedBy",  fields: [createdById],  references: [id], onDelete: SetNull)
  reviewedBy     User?       @relation("TourReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

  createdAt      DateTime    @default(now())
