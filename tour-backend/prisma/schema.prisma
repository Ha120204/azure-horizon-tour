// =============================================
// Há»€ THá»NG Há»” TRá»¢ KHÃCH HÃ€NG (SUPPORT TICKETS)
// =============================================
model SupportTicket {
  id              Int      @id @default(autoincrement())
  accessCode      String?  @default(uuid()) @unique // [FIX] Báº¯t buá»™c dÃ¹ng Ä‘á»ƒ khÃ¡ch vÃ£ng lai xem ticket, chá»‘ng lá»™ dá»¯ liá»‡u
  customerName    String
  customerEmail   String
  customerPhone   String?
  bookingRef      String?                // MÃ£ booking liÃªn quan â€” giá»¯ Ä‘á»ƒ tÆ°Æ¡ng thÃ­ch vá»›i dá»¯ liá»‡u cÅ©
  // â”€â”€ LiÃªn káº¿t FK tháº­t tá»›i Booking [PHASE 1] â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  // DÃ¹ng song song vá»›i bookingRef. bookingId = FK chuáº©n cho ticket má»›i.
  // Dá»¯ liá»‡u cÅ© giá»¯ nguyÃªn bookingRef, khÃ´ng cáº§n migrate.
  bookingId       Int?                   // FK tháº­t tá»›i Booking
  booking         Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  subject         String
  message         String   @db.Text
  category        String   @default("general") // booking|payment|reschedule|complaint|general
  status          String   @default("NEW")     // NEW|IN_PROGRESS|RESOLVED
  assignedStaffId Int?                         // Staff Ä‘Æ°á»£c assign xá»­ lÃ½
  rating          Int?                         // ÄÃ¡nh giÃ¡ cá»§a khÃ¡ch sau khi RESOLVED (1-5)

  // LiÃªn káº¿t tá»›i tÃ i khoáº£n ngÆ°á»i dÃ¹ng (nullable â€” guest submissions khÃ´ng cÃ³)
  userId          Int?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  assistedDrafts  AssistedBookingDraft[]
  replies         TicketReply[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([customerEmail])
  @@index([userId])
  @@index([bookingId])  // [PHASE 1] TÃ¬m ticket theo booking
}

model TicketReply {
