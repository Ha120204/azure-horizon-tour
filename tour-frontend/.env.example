# Azure Horizon — Frontend Environment Variables
# Sao chép file này thành .env.local và điền giá trị phù hợp.
# KHÔNG commit file .env.local (đã được .gitignore).

# URL Backend API (không có dấu / ở cuối)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Secret dùng cho on-demand revalidation (phải khớp với backend)
REVALIDATION_SECRET=
